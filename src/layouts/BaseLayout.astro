---
const { title = "Jaime De La Paz — Enterprise Support Engineer" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@300;700;900&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    [data-theme="dark"] {
      --bg: #0f1117;
      --bg-alt: #13151c;
      --surface: #17191f;
      --border: #1e2028;
      --border-mid: #25272f;
      --text: #f0f2f8;
      --text-dim: #9ca3af;
      --text-muted: #3d4048;
      --accent: #c9a85d;
      --accent-bg: #1a160c;
      --accent-tag: #d4b472;
      --accent-tag-border: #2e2518;
      --card-bg: #13151c;
      --card-border: #1e2028;
      --wip-bg: #1e1a0a;
      --wip-text: #d4a017;
      --wip-border: #2e2810;
    }

    [data-theme="light"] {
      --bg: #ede8dc;
      --bg-alt: #e4ddd0;
      --surface: #dcd5c6;
      --border: #ccc4b2;
      --border-mid: #bcb49e;
      --text: #1c1a16;
      --text-dim: #4a4438;
      --text-muted: #8a8070;
      --accent: #8a6820;
      --accent-bg: #e8dfc8;
      --accent-tag: #7a5c18;
      --accent-tag-border: #c0a870;
      --card-bg: #e4ddd0;
      --card-border: #ccc4b2;
      --wip-bg: #f5ead0;
      --wip-text: #8a5a10;
      --wip-border: #d4b070;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      line-height: 1.7;
      transition: background .3s, color .3s;
    }

    a {
      color: var(--accent-tag);
      text-decoration: none;
      position: relative;
      transition: opacity .2s;
    }
    a::after {
      content: '';
      position: absolute;
      left: 0; bottom: -2px;
      width: 100%; height: 1px;
      background: currentColor;
      opacity: 0.35;
      transform: scaleX(0.5);
      transform-origin: left;
      transition: opacity .2s, transform .2s;
    }
    a:hover { opacity: 1; }
    a:hover::after { opacity: 0.9; transform: scaleX(1); }

    .nav-links a::after,
    .btn-ghost::after,
    .project-link::after,
    .nav-brand a::after { display: none; }

    .wrapper { max-width: 1080px; margin: 0 auto; padding: 0 28px 120px; }

    header {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      transition: background .3s, border-color .3s;
    }
    nav {
      max-width: 1080px; margin: 0 auto; padding: 0 28px;
      height: 58px;
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
    }
    .nav-brand img { height: 38px; width: 38px; border-radius: 50%; object-fit: cover; display: block; }
    .nav-links { display: flex; gap: 4px; list-style: none; align-items: center; }
    .nav-links a {
      font-size: 12px; color: var(--text-dim); padding: 5px 10px; border-radius: 6px;
      transition: color .2s, background .2s;
    }
    .nav-links a:hover { color: var(--accent); background: var(--accent-bg); opacity: 1; }
    .nav-links .nav-resume a {
      color: var(--accent);
      border: 1px solid var(--accent-tag-border);
      border-radius: 6px;
      padding: 4px 10px;
    }
    .nav-links .nav-resume a:hover { background: var(--accent-bg); border-color: var(--accent); }

    #theme-toggle {
      background: var(--surface);
      border: 1px solid var(--border-mid);
      color: var(--text-dim);
      cursor: pointer;
      width: 36px; height: 36px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; flex-shrink: 0;
      transition: background .3s, border-color .2s, color .2s;
    }
    #theme-toggle::after { display: none; }
    #theme-toggle:hover { color: var(--accent); border-color: var(--accent); }

    footer { padding: 40px 0 20px; text-align: center; font-size: 11px; color: var(--text-muted); letter-spacing: .04em; font-family: 'JetBrains Mono', monospace; }
    footer span { color: var(--accent); }

    @media (max-width: 600px) {
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

<header>
  <nav>
    <div class="nav-brand">
      <a href="/"><img src="/logo.png" alt="jaime-builds" /></a>
    </div>
    <ul class="nav-links">
      <li><a href="/">About</a></li>
      <li><a href="/projects">Projects</a></li>
      <li><a href="/homelab">Homelab</a></li>
      <li><a href="/field-notes">Field Notes</a></li>
      <li class="nav-resume"><a href="/resume.pdf" target="_blank" rel="noopener">Resume ↗</a></li>
    </ul>
    <button id="theme-toggle" aria-label="Toggle theme">☀</button>
  </nav>
</header>

<slot />

<footer>
  <p>Jaime A. De La Paz &nbsp;·&nbsp; Rogers City, MI &nbsp;·&nbsp; <span>&copy; 2026</span></p>
</footer>

<script>
  const toggle = document.getElementById('theme-toggle');
  const root = document.documentElement;
  const saved = localStorage.getItem('jb-theme') || 'dark';
  root.setAttribute('data-theme', saved);
  toggle.textContent = saved === 'dark' ? '☀' : '🌙';
  toggle.addEventListener('click', () => {
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    toggle.textContent = next === 'dark' ? '☀' : '🌙';
    localStorage.setItem('jb-theme', next);
  });
</script>

</body>
</html>
